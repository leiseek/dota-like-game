{
  "name": "dota-like-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "build:web": "npm run build && tsc -p platform-web/tsconfig.json",
    "build:pages": "npm run build:web && node scripts/build-pages.mjs",
    "preview:web": "npm run build:web && node platform-web/dev-server.mjs",
    "check:web-boundary": "node scripts/check-web-main-size.mjs",
    "check": "npm run build && npm run test && tsc -p platform-web/tsconfig.json && npm run check:web-boundary"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.5.4"
  }
}
