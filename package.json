{
  "name": "dota-like-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:web": "node --test platform-web/dist/**/*.test.js",
    "build:web": "npm run build && tsc -p platform-web/tsconfig.json",
    "build:pages": "npm run build:web && node scripts/build-pages.mjs",
    "preview:web": "npm run build:web && node platform-web/dev-server.mjs",
    "refactor:web-selection-profiles": "node scripts/refactor-web-selection-profiles.mjs",
    "refactor:web-selection-profiles:dry-run": "node scripts/refactor-web-selection-profiles.mjs --dry-run",
    "check:web-boundary": "node scripts/check-web-main-size.mjs",
    "check:web-refactors": "npm run refactor:web-selection-profiles:dry-run && npm run test:scripts",
    "check": "npm run build && npm run test && tsc -p platform-web/tsconfig.json && npm run test:web && npm run check:web-boundary && npm run check:web-refactors"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.5.4"
  }
}
